# =============================================================================
# Production environment for Coolify.
# Copy these as environment variables into the Coolify application resource.
# DO NOT commit real values. Generate secrets with: openssl rand -hex 32
# =============================================================================

# ---- Application ----
NODE_ENV=production
PORT=4040
API_PREFIX=api
API_VERSION=1
# Comma-separated browser origins allowed to call the API with cookies.
# Set this to your real frontend origin(s); no trailing slash.
CORS_ORIGINS=https://app.yourdomain.com
# Reverse-proxy hops to trust (Coolify/Traefik = 1). Leave at 1 unless you
# add another proxy in front of Coolify.
TRUST_PROXY=1

# ---- Database (PostgreSQL) ----
# When using a Coolify-managed Postgres, DB_HOST is the database resource's
# internal hostname shown in Coolify (NOT localhost, NOT a public IP).
DB_HOST=<coolify-postgres-internal-hostname>
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<strong-db-password>
DB_DATABASE=gameclub
# MUST be false in production — the app boots will refuse 'true'. The schema is
# created and kept current by migrations (run automatically on container boot).
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ---- Auth / JWT ----  (each MUST be >= 32 chars and non-default in prod)
JWT_ACCESS_SECRET=<openssl rand -hex 32>
JWT_REFRESH_SECRET=<openssl rand -hex 32>
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
JWT_REFRESH_TTL_MS=2592000000

# ---- Cookies ----  (true because traffic is served over HTTPS by Coolify)
COOKIE_SECURE=true
# Set if the API and frontend share a parent domain and you want the cookie
# scoped to it, e.g. .yourdomain.com — otherwise leave unset.
# COOKIE_DOMAIN=.yourdomain.com

# ---- First owner account (optional) ----
# If both are set, the container seeds this OWNER account on first boot
# (idempotent). Remove them after the first successful deploy, or leave them —
# re-running does nothing once the account exists.
SEED_OWNER_EMAIL=owner@yourdomain.com
SEED_OWNER_PASSWORD=<strong-initial-owner-password>
