# ---- Application ----
NODE_ENV=development
PORT=4040
API_PREFIX=api
API_VERSION=1
# Comma-separated allowed browser origins (CORS with credentials).
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gameclub
# Dev convenience only. NEVER true in production — use migrations.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ---- Auth / JWT ----
# Use long random values in production (min 16 chars; 32+ recommended).
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
JWT_REFRESH_TTL_MS=2592000000
# Set true behind HTTPS so cookies are only sent over TLS.
COOKIE_SECURE=false
# COOKIE_DOMAIN=.yourdomain.com

# ---- Seed (first owner account) ----
SEED_OWNER_EMAIL=owner@club.uz
SEED_OWNER_PASSWORD=Owner-Passw0rd!
